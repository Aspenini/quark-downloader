#include <windows.h>

#define IDI_APP_ICON 1
#define IDD_MAIN 101
#define IDC_URL 1001
#define IDC_AUDIO 1002
#define IDC_VIDEO 1003
#define IDC_FORMAT 1004
#define IDC_OUTPUT 1005
#define IDC_BROWSE 1006
#define IDD_PROGRESS 102
#define IDC_PROGRESS_STATUS 1007
#define IDC_PROGRESS_BAR 1008
#define IDC_SETTINGS 1009
#define IDD_SETTINGS 103
#define IDC_SET_DOWNLOAD_DIR 1010
#define IDC_SET_BROWSE 1011
#define IDC_SET_YTDLP 1012
#define IDC_SET_FFMPEG 1013
#define IDC_SET_GUI_MODE 1014
#define IDC_SET_LOGS 1015

IDI_APP_ICON ICON "../icons/icon.ico"

IDD_MAIN DIALOGEX 0, 0, 320, 200
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Quark Downloader"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Video URL:", -1, 10, 10, 50, 8
    EDITTEXT        IDC_URL, 10, 22, 300, 14, ES_AUTOHSCROLL

    CONTROL         "Audio", IDC_AUDIO, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 10, 48, 45, 10
    CONTROL         "Video", IDC_VIDEO, "Button", BS_AUTORADIOBUTTON | WS_TABSTOP, 60, 48, 45, 10

    LTEXT           "Format:", -1, 10, 68, 35, 8
    COMBOBOX        IDC_FORMAT, 10, 80, 140, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Output folder:", -1, 10, 108, 60, 8
    EDITTEXT        IDC_OUTPUT, 10, 120, 235, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "Browse...", IDC_BROWSE, 252, 118, 58, 14

    PUSHBUTTON      "...", IDC_SETTINGS, 10, 170, 20, 14
    DEFPUSHBUTTON   "Download", IDOK, 200, 170, 55, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 260, 170, 50, 14
END

IDD_PROGRESS DIALOGEX 0, 0, 400, 110
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Quark Downloader"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Starting download...", IDC_PROGRESS_STATUS, 12, 12, 376, 28
    CONTROL         "", IDC_PROGRESS_BAR, "msctls_progress32", PBS_SMOOTH | WS_CHILD | WS_VISIBLE, 12, 48, 376, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 338, 82, 50, 14
END

IDD_SETTINGS DIALOGEX 0, 0, 360, 210
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Quark Downloader Settings"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Default folder:", -1, 10, 10, 70, 8
    EDITTEXT        IDC_SET_DOWNLOAD_DIR, 10, 22, 278, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "Browse...", IDC_SET_BROWSE, 296, 20, 58, 14

    LTEXT           "yt-dlp:", -1, 10, 50, 40, 8
    COMBOBOX        IDC_SET_YTDLP, 10, 62, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "ffmpeg:", -1, 150, 50, 40, 8
    COMBOBOX        IDC_SET_FFMPEG, 150, 62, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "GUI download:", -1, 10, 96, 70, 8
    COMBOBOX        IDC_SET_GUI_MODE, 10, 108, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    CONTROL         "Create download logs", IDC_SET_LOGS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 150, 110, 120, 10

    DEFPUSHBUTTON   "Save", IDOK, 248, 184, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 304, 184, 50, 14
END
