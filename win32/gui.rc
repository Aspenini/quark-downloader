#include <windows.h>

#define IDI_APP_ICON 1
#define IDD_MAIN 101
#define IDC_URL 1001
#define IDC_AUDIO 1002
#define IDC_VIDEO 1003
#define IDC_FORMAT 1004
#define IDC_OUTPUT 1005
#define IDC_BROWSE 1006
#define IDD_PROGRESS 102
#define IDC_PROGRESS_STATUS 1007
#define IDC_PROGRESS_BAR 1008
#define IDC_SETTINGS 1009
#define IDC_SET_DOWNLOAD_DIR 1010
#define IDC_SET_BROWSE 1011
#define IDC_SET_YTDLP 1012
#define IDC_SET_FFMPEG 1013
#define IDC_SET_GUI_MODE 1014
#define IDC_SET_LOGS 1015
#define IDC_MAIN_URL_LABEL 1016
#define IDC_MAIN_FORMAT_LABEL 1017
#define IDC_MAIN_OUTPUT_LABEL 1018
#define IDC_SET_DOWNLOAD_LABEL 1019
#define IDC_SET_YTDLP_LABEL 1020
#define IDC_SET_FFMPEG_LABEL 1021
#define IDC_SET_GUI_MODE_LABEL 1022
#define IDC_SET_SAVE 1023
#define IDC_SET_CANCEL 1024
#define IDC_CHECK_UPDATES 1025
#define IDC_PROGRESS_ETA 1026
#define IDC_PROGRESS_QUEUE 1027
#define IDC_URL_ADD 1028
#define IDC_QUEUE_LIST 1029
#define IDC_QUEUE_REMOVE 1030
#define IDC_MAIN_QUEUE_LABEL 1031
#define IDC_SET_STRIP_IDS 1032
#define IDC_SET_SANITIZE 1033
#define IDC_SET_SPACES 1034
#define IDC_SET_SPACES_LABEL 1035
#define IDC_SET_PLAYLIST_FOLDERS 1036
#define IDC_GRP_GENERAL 1037
#define IDC_GRP_NAMING 1038
#define IDC_GRP_DOWNLOADS 1039
#define IDC_GRP_TOOLS 1040

IDI_APP_ICON ICON "../icons/icon.ico"

IDD_MAIN DIALOGEX 0, 0, 360, 314
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Quark Downloader"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Video or playlist URL:", IDC_MAIN_URL_LABEL, 10, 10, 100, 8
    EDITTEXT        IDC_URL, 10, 22, 296, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "Add", IDC_URL_ADD, 312, 21, 38, 14

    LTEXT           "Queue:", IDC_MAIN_QUEUE_LABEL, 10, 44, 50, 8
    PUSHBUTTON      "Remove", IDC_QUEUE_REMOVE, 296, 42, 54, 14
    LISTBOX         IDC_QUEUE_LIST, 10, 58, 340, 60, LBS_NOTIFY | WS_VSCROLL | WS_BORDER | WS_TABSTOP

    CONTROL         "Audio", IDC_AUDIO, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 10, 126, 45, 10
    CONTROL         "Video", IDC_VIDEO, "Button", BS_AUTORADIOBUTTON | WS_TABSTOP, 60, 126, 45, 10

    LTEXT           "Format:", IDC_MAIN_FORMAT_LABEL, 10, 146, 35, 8
    COMBOBOX        IDC_FORMAT, 10, 158, 140, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Output folder:", IDC_MAIN_OUTPUT_LABEL, 10, 186, 60, 8
    EDITTEXT        IDC_OUTPUT, 10, 198, 275, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "Browse...", IDC_BROWSE, 292, 196, 58, 14

    PUSHBUTTON      "...", IDC_SETTINGS, 10, 290, 20, 14
    DEFPUSHBUTTON   "Download", IDOK, 248, 290, 55, 14
    PUSHBUTTON      "Close", IDCANCEL, 304, 290, 50, 14

    GROUPBOX        "General", IDC_GRP_GENERAL, 7, 4, 346, 52
    LTEXT           "Default download folder:", IDC_SET_DOWNLOAD_LABEL, 14, 16, 120, 8
    EDITTEXT        IDC_SET_DOWNLOAD_DIR, 14, 28, 266, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "Browse...", IDC_SET_BROWSE, 288, 26, 58, 14

    GROUPBOX        "Download naming", IDC_GRP_NAMING, 7, 60, 346, 86
    CONTROL         "Remove trailing video ID from filenames", IDC_SET_STRIP_IDS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 72, 320, 10
    CONTROL         "Sanitize filenames (ASCII-safe)", IDC_SET_SANITIZE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 86, 320, 10
    LTEXT           "Spaces in filenames:", IDC_SET_SPACES_LABEL, 14, 102, 80, 8
    COMBOBOX        IDC_SET_SPACES, 100, 100, 90, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CONTROL         "Put playlists in their own folder", IDC_SET_PLAYLIST_FOLDERS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 120, 320, 10

    GROUPBOX        "Downloads", IDC_GRP_DOWNLOADS, 7, 150, 346, 48
    LTEXT           "Download window:", IDC_SET_GUI_MODE_LABEL, 14, 162, 80, 8
    COMBOBOX        IDC_SET_GUI_MODE, 14, 174, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CONTROL         "Create download logs", IDC_SET_LOGS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 150, 176, 120, 10

    GROUPBOX        "Tools", IDC_GRP_TOOLS, 7, 202, 346, 46
    LTEXT           "yt-dlp:", IDC_SET_YTDLP_LABEL, 14, 214, 40, 8
    COMBOBOX        IDC_SET_YTDLP, 14, 226, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "ffmpeg:", IDC_SET_FFMPEG_LABEL, 150, 214, 40, 8
    COMBOBOX        IDC_SET_FFMPEG, 150, 226, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    PUSHBUTTON      "Check for updates...", IDC_CHECK_UPDATES, 10, 290, 110, 14
    DEFPUSHBUTTON   "Save", IDC_SET_SAVE, 248, 290, 50, 14
    PUSHBUTTON      "Cancel", IDC_SET_CANCEL, 304, 290, 50, 14
END

IDD_PROGRESS DIALOGEX 0, 0, 400, 118
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX
CAPTION "Quark Downloader"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Starting download...", IDC_PROGRESS_STATUS, 12, 12, 376, 28
    LTEXT           "", IDC_PROGRESS_QUEUE, 12, 42, 376, 10
    CONTROL         "", IDC_PROGRESS_BAR, "msctls_progress32", PBS_SMOOTH | WS_CHILD | WS_VISIBLE, 12, 56, 376, 14
    LTEXT           "Time left: estimating...", IDC_PROGRESS_ETA, 12, 76, 250, 10
    PUSHBUTTON      "Cancel", IDCANCEL, 338, 90, 50, 14
END
